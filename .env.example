# HearThat — environment configuration
# Copy this file to `.env` and fill in your endpoints.
# Authentication uses Entra ID via DefaultAzureCredential — DO NOT put API keys here.
# Run `az login` once on your machine and the SDKs will pick up your credentials.

# ---------- Azure OpenAI ----------
AZURE_OPENAI_ENDPOINT=https://your-foundry-project.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Deployment names (created in Azure AI Foundry)
AZURE_OPENAI_DEPLOYMENT_SUMMARY=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT_VISION=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT_TTS=gpt-4o-mini-tts
AZURE_OPENAI_DEPLOYMENT_TRANSCRIBE=gpt-4o-mini-transcribe

# ---------- Azure Speech ----------
AZURE_SPEECH_ENDPOINT=https://eastus.api.cognitive.microsoft.com/
AZURE_SPEECH_REGION=eastus
# Default voice: MAI-Voice-1 Iris (Narration). Fallback: DragonHDOmni Ava.
HEARTHAT_DEFAULT_VOICE=en-us-Iris:MAI-Voice-1
HEARTHAT_FALLBACK_VOICE=en-US-Ava:DragonHDOmniLatestNeural

# ---------- Azure Document Intelligence ----------
AZURE_DOCINTEL_ENDPOINT=https://your-docintel.cognitiveservices.azure.com/

# ---------- Azure Translator (Document Translation) ----------
AZURE_TRANSLATOR_ENDPOINT=https://your-translator.cognitiveservices.azure.com/

# ---------- Azure Storage (translation only) ----------
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_STORAGE_SOURCE_CONTAINER=source
AZURE_STORAGE_TARGET_CONTAINER=target

# ---------- HearThat runtime ----------
HEARTHAT_DATA_DIR=./data
HEARTHAT_DB_PATH=./hearthat.db
HEARTHAT_LOG_LEVEL=INFO
